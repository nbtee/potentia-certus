# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your-project-url.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Edge Function Configuration (for Anthropic API proxy)
# Note: The actual Anthropic API key should be stored in Supabase Vault or as an Edge Function secret
# DO NOT put the Anthropic API key here - it should never be in the Next.js environment

# SQL Server (Bullhorn mirror)
SQL_SERVER_HOST=your-sql-server.database.windows.net
SQL_SERVER_DATABASE=your-database
SQL_SERVER_USER=your-user
SQL_SERVER_PASSWORD=your-password

# Cron sync secret (used to authenticate /api/cron/sync)
CRON_SECRET=your-cron-secret

# Development Configuration
PORT=3001